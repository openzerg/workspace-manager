{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "types": ["bun-types"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@openzerg/common": ["../common/client/src/index-node.ts"],
      "@openzerg/common/gen/*": ["../common/generated/ts/gen/*"],
      "@openzerg/common/entities/*": ["../common/generated/ts/entities/*"],
      "@openzerg/common/queries": ["../common/generated/ts/queries.ts"]
    }
  },
  "include": ["src/**/*"]
}
